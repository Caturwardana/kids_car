#include <EEPROM.h>

// ===== PIN MAPPING STM32 =====
// 1. DRIVE BTS7960
#define RPWM_DRIVE PA1  // Maju (Diubah sesuai request)
#define LPWM_DRIVE PA0  // Mundur (Diubah sesuai request)
#define R_EN_DRIVE PA3  // (Diubah sesuai request)
#define L_EN_DRIVE PA2  // (Diubah sesuai request)

// 2. STEERING BTS7960
#define RPWM_STEER PB0  // Belok Kanan
#define LPWM_STEER PB1  // Belok Kiri
#define R_EN_STEER PB10
#define L_EN_STEER PB11

// 3. MANUAL CONTROL (PEDAL)
#define INPUT_FORWARD  PB13
#define INPUT_BACKWARD PB14

// 4. ADC INTERNAL STM32 PENGGANTI ADS1115
#define ADC_STIR PA4  
#define ADC_RODA PA5  
#define ADC_VBAT PA6  

// ===== STRUKTUR DATA EEPROM =====
struct Config {
  long magic;
  int lk, rk, mid, dz;
  int spm, sta, bel;
  int ac, acc, man;
  int pk, pr, zgp, dzm;
  float vbc;
  int stallTimeout; 
};
Config cfg;

// ===== VARIABEL PARAMETER RAM =====
int speedPWM, belokPWM;      
int limitKiri, limitKanan;    
int startDrivePWM; 
int adcTengah, deadzone;
int autoCenter; 
int accelTime;  
int manualMode; 
int potKiri, potKanan; 
float vbatCalib; 
int dzMan, stirGap;
int stallTimeout;    

String currentDrive = "stop";
String currentSteer = "lurus";

// ===== VARIABEL TIMING & NON-BLOCKING =====
unsigned long lastLimitCheck = 0;
unsigned long lastBTCmdTime = 0; 
String btBuffer = ""; // Buffer untuk non-blocking serial read

int drivePhase = 0; 
unsigned long driveTimer = 0;
String pendingDrive = "";
int currentPWM = 0;
int activeDrivePin = 0;

String pendingSteer = "lurus";

// ===== VARIABEL FILTER & ZONA =====
float smoothedRoda = 0;
float smoothedStir = 0;
int currentZone = 2; 

// ===== VARIABEL STALL DETECTION =====
unsigned long steerCheckTimer = 0;
int16_t lastStirADC = 0;
bool isSteerStalled = false;
const int STALL_THRESHOLD = 5; 

// ===== SETUP =====
void setup() {
    // === HACK USB BLUE PILL REVISI ===
  pinMode(PA12, OUTPUT);
  digitalWrite(PA12, LOW);
  delay(100); 
  pinMode(PA12, INPUT); 
  delay(100); 
  // ===================================
  
  Serial.begin(115200);   
  Serial1.begin(9600);    

  Serial.println("\n[SYSTEM] Memulai Proses Setup...");

  pinMode(INPUT_FORWARD, INPUT_PULLUP);
  pinMode(INPUT_BACKWARD, INPUT_PULLUP);

  pinMode(RPWM_DRIVE, OUTPUT); pinMode(LPWM_DRIVE, OUTPUT);
  pinMode(R_EN_DRIVE, OUTPUT); pinMode(L_EN_DRIVE, OUTPUT);
  digitalWrite(R_EN_DRIVE, LOW); digitalWrite(L_EN_DRIVE, LOW);

  pinMode(RPWM_STEER, OUTPUT); pinMode(LPWM_STEER, OUTPUT);
  pinMode(R_EN_STEER, OUTPUT); pinMode(L_EN_STEER, OUTPUT);
  digitalWrite(R_EN_STEER, LOW); digitalWrite(L_EN_STEER, LOW);
  
  pinMode(ADC_STIR, INPUT_ANALOG);
  pinMode(ADC_RODA, INPUT_ANALOG);
  pinMode(ADC_VBAT, INPUT_ANALOG);

  analogWriteResolution(8);
  analogReadResolution(12); 

  loadConfig();
  stopAll();
  
  Serial.println("[SYSTEM] Setup Selesai. STM32 RC Controller Ready!");
  Serial1.println("STM32 Ready! (Optimized & Fast BT)");
  btBuffer.reserve(50); // Mencegah fragmentasi memori
}

// ==========================================
// ===== FUNGSI EEPROM ======================
// ==========================================
void loadConfig() {
  EEPROM.get(0, cfg);
  if (cfg.magic != 99999999) { 
    Serial.println("[EEPROM] Magic number tidak cocok, inisialisasi default parameter!");
    cfg.magic = 99999999;
    cfg.lk = 450; cfg.rk = 1050; cfg.mid = 775; cfg.dz = 20;
    cfg.spm = 80; cfg.sta = 5; cfg.bel = 150; cfg.ac = 1;
    cfg.acc = 1500; cfg.man = 0; cfg.pk = 1548; cfg.pr = 591;
    cfg.vbc = 0.0075; cfg.zgp = 10; cfg.dzm = 30; cfg.stallTimeout = 500; 
    EEPROM.put(0, cfg);
  } else {
    Serial.println("[EEPROM] Konfigurasi berhasil diload.");
  }
  
  limitKiri = cfg.lk; limitKanan = cfg.rk; adcTengah = cfg.mid; deadzone = cfg.dz;
  speedPWM = cfg.spm; startDrivePWM = cfg.sta; belokPWM = cfg.bel; autoCenter = cfg.ac;
  accelTime = cfg.acc; manualMode = cfg.man; potKiri = cfg.pk; potKanan = cfg.pr;
  vbatCalib = cfg.vbc; stirGap = cfg.zgp; dzMan = cfg.dzm; stallTimeout = cfg.stallTimeout;
}

void saveConfig() {
  cfg.lk = limitKiri; cfg.rk = limitKanan; cfg.mid = adcTengah; cfg.dz = deadzone;
  cfg.spm = speedPWM; cfg.sta = startDrivePWM; cfg.bel = belokPWM; cfg.ac = autoCenter;
  cfg.acc = accelTime; cfg.man = manualMode; cfg.pk = potKiri; cfg.pr = potKanan;
  cfg.zgp = stirGap; cfg.dzm = dzMan; cfg.vbc = vbatCalib; cfg.stallTimeout = stallTimeout;
  EEPROM.put(0, cfg);
  Serial.println("[EEPROM] Settings berhasil disimpan!");
  Serial1.println("OK:SAVED");
}

// ==========================================
// ===== FUNGSI SETIR & DRIVE (BTS7960) =====
// ==========================================
void steerTo(String arah, int pwm) {
  if (pendingSteer != arah) {
    isSteerStalled = false;
    steerCheckTimer = millis();
    lastStirADC = (int16_t)smoothedRoda; 
  }
  if (isSteerStalled) return; 

  pendingSteer = arah;
  digitalWrite(R_EN_STEER, HIGH); digitalWrite(L_EN_STEER, HIGH);
  if (arah == "kanan") { analogWrite(LPWM_STEER, 0); analogWrite(RPWM_STEER, pwm); } 
  else if (arah == "kiri") { analogWrite(RPWM_STEER, 0); analogWrite(LPWM_STEER, pwm); }
}

void stopSteer() {
  analogWrite(RPWM_STEER, 0); analogWrite(LPWM_STEER, 0);
  digitalWrite(R_EN_STEER, LOW); digitalWrite(L_EN_STEER, LOW);
  currentSteer = "lurus"; pendingSteer = "lurus"; isSteerStalled = false; 
}

void stopDrive() {
  analogWrite(RPWM_DRIVE, 0); analogWrite(LPWM_DRIVE, 0);
  digitalWrite(R_EN_DRIVE, LOW); digitalWrite(L_EN_DRIVE, LOW);
  if (drivePhase != 1) { currentDrive = "stop"; pendingDrive = ""; }
}

void executeMaju() {
  currentDrive = "maju"; digitalWrite(R_EN_DRIVE, HIGH); digitalWrite(L_EN_DRIVE, HIGH);
  activeDrivePin = RPWM_DRIVE; currentPWM = startDrivePWM;
  analogWrite(LPWM_DRIVE, 0); analogWrite(RPWM_DRIVE, currentPWM);
  drivePhase = 2; driveTimer = millis();
}

void executeMundur() {
  currentDrive = "mundur"; digitalWrite(R_EN_DRIVE, HIGH); digitalWrite(L_EN_DRIVE, HIGH);
  activeDrivePin = LPWM_DRIVE; currentPWM = startDrivePWM;
  analogWrite(RPWM_DRIVE, 0); analogWrite(LPWM_DRIVE, currentPWM);
  drivePhase = 2; driveTimer = millis();
}

void stopAll() { stopDrive(); stopSteer(); }

// ===== LOOP =====
void loop() {
  handleBluetoothNonBlocking(); // Fungsi baru lebih ringan
  
  // ========================================================
  // BACA ADC INTERNAL STM32
  // ========================================================
  int16_t rawAdcRoda = analogRead(ADC_RODA);
  rawAdcRoda = 4095 - rawAdcRoda; // HACK Roda kebalik
  
  int16_t rawAdcStir = analogRead(ADC_STIR);

  if (smoothedRoda == 0) smoothedRoda = rawAdcRoda;
  if (smoothedStir == 0) smoothedStir = rawAdcStir;

  smoothedRoda = (0.3 * rawAdcRoda) + (0.7 * smoothedRoda);
  smoothedStir = (0.05 * rawAdcStir) + (0.95 * smoothedStir);

  int16_t adcRoda = (int16_t)smoothedRoda;
  int16_t adcStir = (int16_t)smoothedStir;
  
  bool pedalFwd = (digitalRead(INPUT_FORWARD) == LOW);
  bool pedalBwd = (digitalRead(INPUT_BACKWARD) == LOW);
  
  // Logger 1 Detik
  static unsigned long lastDebugLog = 0;
  if (millis() - lastDebugLog >= 1000) {
    lastDebugLog = millis();
    Serial.print("[STATUS] Roda: "); Serial.print(adcRoda);
    Serial.print(" | Drive: "); Serial.print(currentDrive);
    Serial.print(" | Steer: "); Serial.println(currentSteer);
  }

  // Timeout Safety
  bool btOverride = (millis() - lastBTCmdTime < 3000); 
  if (!btOverride && currentDrive != "stop" && !pedalFwd && !pedalBwd) stopDrive();

  // LIMIT CHECK
  if (millis() - lastLimitCheck >= 30) {
    lastLimitCheck = millis();
    if (currentSteer != "lurus" && currentSteer != "centering") {
      if (pendingSteer == "kiri" && adcRoda <= limitKiri) stopSteer();
      else if (pendingSteer == "kanan" && adcRoda >= limitKanan) stopSteer();
    }
  }

  // STALL DETECTION
  if (pendingSteer != "lurus" && !isSteerStalled) {
    if (millis() - steerCheckTimer >= stallTimeout) {
      int pergerakan = abs(adcRoda - lastStirADC);
      if (pergerakan < STALL_THRESHOLD) { stopSteer(); isSteerStalled = true; Serial1.println("WARN:STALL"); } 
      else { steerCheckTimer = millis(); lastStirADC = adcRoda; }
    }
  }

  // MANUAL CONTROL
  if (manualMode == 1 && !btOverride) {
    if (pedalFwd && !pedalBwd && pendingDrive != "maju") {
       stopDrive(); pendingDrive = "maju"; drivePhase = (currentDrive == "mundur") ? 1 : 0;
       if(drivePhase==0) executeMaju(); else driveTimer=millis();
    } else if (pedalBwd && !pedalFwd && pendingDrive != "mundur") {
       stopDrive(); pendingDrive = "mundur"; drivePhase = (currentDrive == "maju") ? 1 : 0;
       if(drivePhase==0) executeMundur(); else driveTimer=millis();
    } else if (!pedalFwd && !pedalBwd && currentDrive != "stop") { stopDrive(); }

    int persenStir = constrain(map(adcStir, potKiri, potKanan, 0, 100), 0, 100);
    if (persenStir < (33 - stirGap)) currentZone = 1; 
    else if (persenStir > (33 + stirGap) && persenStir < (66 - stirGap)) currentZone = 2; 
    else if (persenStir > (66 + stirGap)) currentZone = 3; 
    
    int targetADC = adcTengah;
    if (currentZone == 1) targetADC = limitKiri;
    else if (currentZone == 3) targetADC = limitKanan;

    if (abs(adcRoda - targetADC) > dzMan) steerTo((adcRoda < targetADC) ? "kanan" : "kiri", belokPWM);
    else if (currentSteer != "lurus") stopSteer();
  }

  // AUTO CENTER
  if (currentSteer == "centering" && (manualMode == 0 || btOverride)) {
    int errorCenter = abs(adcRoda - adcTengah);
    if (errorCenter <= deadzone) stopSteer(); 
    else {
      int pwmBalik = belokPWM;
      if (errorCenter <= 60) pwmBalik = map(errorCenter, deadzone, 60, startDrivePWM, belokPWM);
      steerTo((adcRoda < adcTengah) ? "kanan" : "kiri", pwmBalik);
    }
  }

  // DRIVE STATE MACHINE
  if (drivePhase == 1 && millis() - driveTimer >= 300) {
    if (pendingDrive == "maju") executeMaju(); else if (pendingDrive == "mundur") executeMundur();
  } else if (drivePhase == 2) {
    unsigned long elapsed = millis() - driveTimer;
    if (elapsed >= accelTime) { currentPWM = speedPWM; drivePhase = 0; } 
    else currentPWM = startDrivePWM + ((speedPWM - startDrivePWM) * elapsed / accelTime);
    analogWrite(activeDrivePin, currentPWM);
  }
}

// ==========================================
// ===== HANDLER BLUETOOTH (NON-BLOCKING) ===
// ==========================================
void handleBluetoothNonBlocking() {
  while (Serial1.available()) {
    char c = (char)Serial1.read();
    if (c == '\n') { // Jika enter (baris baru) diterima
      btBuffer.trim();
      if (btBuffer.length() > 0) processCommand(btBuffer);
      btBuffer = ""; // Kosongkan buffer untuk pesan berikutnya
    } else {
      btBuffer += c; // Masukkan ke buffer
    }
  }
}

// ==========================================
// ===== PROSES COMMAND (SINGKAT/CEPAT) =====
// ==========================================
void processCommand(String cmd) {
  lastBTCmdTime = millis(); 
  Serial.print("[BT] Cmd: "); Serial.println(cmd);
  
  if (cmd == "P") { /* Ping doang */ }
  else if (cmd == "T") { // telemetry
    float vbat = analogRead(ADC_VBAT) * vbatCalib; 
    String json = "{\"v\":" + String(vbat, 1) + ",\"r\":" + String((int16_t)smoothedRoda) + ",\"s\":" + String((int16_t)smoothedStir) + "}";
    Serial1.println(json); // Telemetry juga dipendekkan (v, r, s)
  }
  else if (cmd == "F") { // Maju (Dulu "maju")
    if (pendingDrive != "maju") { stopDrive(); pendingDrive = "maju"; drivePhase = (currentDrive == "mundur") ? 1 : 0; if(drivePhase==0) executeMaju(); else driveTimer=millis(); }
  }
  else if (cmd == "B") { // Mundur (Dulu "mundur")
    if (pendingDrive != "mundur") { stopDrive(); pendingDrive = "mundur"; drivePhase = (currentDrive == "maju") ? 1 : 0; if(drivePhase==0) executeMundur(); else driveTimer=millis(); }
  }
  else if (cmd == "S") { // Release Drive (Dulu "release_drive")
    stopDrive();
  }
  else if (cmd == "L") { // Kiri (Dulu "kiri")
    if(smoothedRoda > limitKiri) { currentSteer = "manual"; steerTo("kiri", belokPWM); } 
  }
  else if (cmd == "R") { // Kanan (Dulu "kanan")
    if(smoothedRoda < limitKanan) { currentSteer = "manual"; steerTo("kanan", belokPWM); } 
  }
  else if (cmd == "C") { // Release Steer/Center (Dulu "release_steer")
    if (autoCenter == 1) currentSteer = "centering"; else stopSteer(); 
  }
  // Parameter tetap sama krn jarang dieksekusi terus-menerus
  else if (cmd == "get_params") {
    String json = "{\"lk\":" + String(limitKiri) + ",\"rk\":" + String(limitKanan) + ",\"mid\":" + String(adcTengah) + ",\"dz\":" + String(deadzone) + ",\"spm\":" + String(speedPWM) + ",\"sta\":" + String(startDrivePWM) + ",\"bel\":" + String(belokPWM) + ",\"ac\":" + String(autoCenter) + ",\"acc\":" + String(accelTime) + ",\"man\":" + String(manualMode) + ",\"pk\":" + String(potKiri) + ",\"pr\":" + String(potKanan) + ",\"zgp\":" + String(stirGap) + ",\"dzm\":" + String(dzMan) + ",\"stt\":" + String(stallTimeout) + "}";
    Serial1.println(json);
  }
  else if (cmd.startsWith("set_params:")) {
    String params = cmd.substring(11) + ","; 
    int pos = 0;
    while ((pos = params.indexOf(',')) != -1) {
      String token = params.substring(0, pos);
      int eqIndex = token.indexOf('=');
      if (eqIndex != -1) {
        String key = token.substring(0, eqIndex);
        int val = token.substring(eqIndex + 1).toInt();
        if (key == "lk") limitKiri = val; else if (key == "rk") limitKanan = val; else if (key == "mid") adcTengah = val; else if (key == "dz") deadzone = val; else if (key == "spm") speedPWM = val; else if (key == "sta") startDrivePWM = val; else if (key == "bel") belokPWM = val; else if (key == "ac") autoCenter = val; else if (key == "acc") accelTime = val; else if (key == "man") manualMode = val; else if (key == "pk") potKiri = val; else if (key == "pr") potKanan = val; else if (key == "zgp") stirGap = val; else if (key == "dzm") dzMan = val; else if (key == "stt") stallTimeout = val; 
      }
      params = params.substring(pos + 1);
    }
    saveConfig();
  }
  else if (cmd.startsWith("cal_vbat:")) {
    float actualV = cmd.substring(9).toFloat();
    int16_t rawAdc = analogRead(ADC_VBAT);
    if (rawAdc > 0) { vbatCalib = actualV / rawAdc; saveConfig(); }
  }
}
